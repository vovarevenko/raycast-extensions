{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "raycast-triage",
  "version": "1.0.1",
  "title": "Triage",
  "description": "Quickly capture reminders to Apple Reminders with priority and dates",
  "icon": "extension-icon.png",
  "author": "vovarevenko",
  "categories": [
    "Productivity"
  ],
  "platforms": [
    "macOS"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "triage",
      "title": "Triage",
      "description": "Add a reminder to the Triage list",
      "mode": "no-view",
      "keywords": [
        "reminder",
        "todo",
        "capture",
        "inbox"
      ],
      "arguments": [
        {
          "name": "text",
          "placeholder": "Fix the printer !!!",
          "type": "text",
          "required": true
        },
        {
          "name": "due",
          "placeholder": "1d, 20.09, 2d 14:30",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "listName",
      "title": "Reminders List",
      "description": "Name of the Apple Reminders list to add reminders to",
      "type": "textfield",
      "default": "Triage",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.9",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.x",
    "eslint": "^8.57.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "publish": "npx @raycast/api@latest publish",
    "check": "run-p --continue-on-error check:*",
    "check:code": "ray lint",
    "check:format": "prettier . --check",
    "check:types": "tsc --noEmit",
    "fix": "run-s fix:*",
    "fix:code": "ray lint --fix",
    "fix:format": "prettier . --write",
    "test": "vitest run"
  }
}
